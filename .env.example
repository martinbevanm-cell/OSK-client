# Copy to .env.local and fill in. Never commit real secrets.

# REST API (osk-backend)
# Required in all environments. Prefer same-origin /api/v1 so auth cookies
# stay first-party and survive incognito restrictions.
# Local:  /api/v1
# Prod:   /api/v1
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Server-side proxy target for /api/v1 rewrites (Next.js only; not public).
# Local:  http://localhost:5000
# Prod:   https://osk-backend-production.up.railway.app
API_PROXY_ORIGIN=http://localhost:5000

# Realtime socket origin.
# Optional: leave empty to derive from NEXT_PUBLIC_API_BASE_URL origin.
# Local:  http://localhost:5000
# Prod:   https://api.your-domain.com
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000

# Site
# Public frontend URL used for metadata/canonical links.
# Local:  http://localhost:3000
# Prod:   https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=OSK

# Maps — MapLibre GL style URL. OpenFreeMap is free: no API key, no card.
# Swap for MapTiler / Stadia / self-hosted tiles with no code change.
NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty

# Theme: theme-luxe-light | theme-luxe-dark | theme-emerald | theme-sandstone
NEXT_PUBLIC_DEFAULT_THEME=theme-luxe-light

# Error tracking (Sentry-compatible) — optional
NEXT_PUBLIC_SENTRY_DSN=

# Note: payment provider credentials are configured on the backend side
# (and/or Admin > Pricing), not in frontend public env vars.
